<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <remote name="couchbase-priv" fetch="ssh://git@github.com/couchbase/" review="review.couchbase.org" />
  <remote name="couchbase" fetch="https://github.com/couchbase" review="review.couchbase.org" />
  <remote name="couchbasedeps" fetch="https://github.com/couchbasedeps/" review="review.couchbase.org" />
  <remote name="couchbaselabs" fetch="https://github.com/couchbaselabs/" review="review.couchbase.org" />
  <remote name="apache" fetch="https://github.com/apache/" />
  <remote name="tableau" fetch="https://github.com/tableau/" />

  <default remote="couchbase" revision="master"/>

  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->
  <!-- Main source: Supported by Couchbase Analytics team -->
  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->
  <project name="couchbase-tableau-connector" remote="couchbase-priv" revision="master" path="."/>

  <!-- Apache AsterixDB Clients -->
  <project name="asterixdb-clients" remote="apache" revision="master" path="asterixdb-clients" />

  <!-- Couchbase JDBC Driver -->
  <project name="couchbase-jdbc-driver" remote="couchbaselabs" revision="main" path="couchbase-jdbc-driver" />

  <!-- Tableau Connector SDK (tdvt-2.13.7) -->
  <project name="connector-plugin-sdk" remote="tableau" revision="f5c30e024564c2057ddf0a8b724848fe46913afc" path="connector-plugin-sdk" groups="notdefault"/>

  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->
  <!-- Build support - build scripts, etc.                -->
  <!-- ++++++++++++++++++++++++++++++++++++++++++++++++++ -->
  <project name="build" path="cbbuild" revision="c1b485bbf14aa1176be5ea26b7982f4002188429" remote="couchbase">
    <annotation name="VERSION" value="0.0.0" keep="true"/>
    <!-- SDK flavor(s) of the connector to build. One of:
           analytics    -> new Analytics SDK   (enterprise-analytics taco)
           operational  -> legacy core SDK     (couchbase-analytics taco)
           both         -> build both tacos
         to default the BUILD_ANALYTICS_SDK / BUILD_OPERATIONAL_SDK options. -->
    <annotation name="SDK" value="both" keep="true"/>
  </project>

  <project name="product-texts"/>
</manifest>
